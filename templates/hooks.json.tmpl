{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$LEGIO_AGENT_NAME\" ] && exit 0; legio prime --agent $LEGIO_AGENT_NAME"
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$LEGIO_AGENT_NAME\" ] && exit 0; legio mail check --inject --agent $LEGIO_AGENT_NAME"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "AskUserQuestion",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$LEGIO_AGENT_NAME\" ] && exit 0; echo '{\"decision\":\"block\",\"reason\":\"Legio agents run non-interactively — use legio mail send --type question to ask your parent instead\"}'"
					}
				]
			},
			{
				"matcher": "EnterPlanMode",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$LEGIO_AGENT_NAME\" ] && exit 0; echo '{\"decision\":\"block\",\"reason\":\"Legio agents run non-interactively — execute immediately per the propulsion principle\"}'"
					}
				]
			},
			{
				"matcher": "EnterWorktree",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$LEGIO_AGENT_NAME\" ] && exit 0; echo '{\"decision\":\"block\",\"reason\":\"Legio agents already have assigned worktrees — nested worktrees are not allowed\"}'"
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$LEGIO_AGENT_NAME\" ] && exit 0; read -r INPUT; CMD=$(echo \"$INPUT\" | sed 's/.*\"command\": *\"\\([^\"]*\\)\".*/\\1/'); if echo \"$CMD\" | grep -qE '\\bgit\\s+push\\b'; then echo '{\"decision\":\"block\",\"reason\":\"git push is blocked — use legio merge to integrate changes, push manually when ready\"}'; exit 0; fi;"
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$LEGIO_AGENT_NAME\" ] && exit 0; read -r INPUT; CMD=$(echo \"$INPUT\" | sed 's/.*\"command\": *\"\\([^\"]*\\)\".*/\\1/'); if echo \"$CMD\" | grep -qE '\\bsleep\\b'; then echo '{\"decision\":\"block\",\"reason\":\"sleep is blocked in legio agents - mail delivery is automatic via hooks, no polling needed\"}'; exit 0; fi;"
					}
				]
			},
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$LEGIO_AGENT_NAME\" ] && exit 0; legio log tool-start --agent $LEGIO_AGENT_NAME --stdin"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$LEGIO_AGENT_NAME\" ] && exit 0; legio log tool-end --agent $LEGIO_AGENT_NAME --stdin"
					},
					{
						"type": "command",
						"command": "[ -z \"$LEGIO_AGENT_NAME\" ] && exit 0; legio mail check --inject --agent $LEGIO_AGENT_NAME --signal"
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$LEGIO_AGENT_NAME\" ] && exit 0; read -r INPUT; CMD=$(echo \"$INPUT\" | sed 's/.*\"command\": *\"\\([^\"]*\\)\".*/\\1/'); if echo \"$CMD\" | grep -qE '\\bgit\\s+commit\\b'; then git rev-parse HEAD~1 >/dev/null 2>&1 && mulch diff HEAD~1; fi;"
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$LEGIO_AGENT_NAME\" ] && exit 0; legio log session-end --agent $LEGIO_AGENT_NAME --stdin"
					},
					{
						"type": "command",
						"command": "[ -z \"$LEGIO_AGENT_NAME\" ] && exit 0; mulch learn"
					}
				]
			}
		],
		"PreCompact": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$LEGIO_AGENT_NAME\" ] && exit 0; legio prime --agent $LEGIO_AGENT_NAME --compact"
					}
				]
			}
		]
	}
}
